#!/usr/bin/env node
import { Command } from 'commander';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

const program = new Command();
const pkg = JSON.parse(readFileSync(join(import.meta.dirname, '..', 'package.json'), 'utf-8'));

program
  .name('opencode-clawmessenger')
  .description('魂器 ClawMessenger 连接器')
  .version(pkg.version);

program
  .command('setup')
  .description('生成注册二维码')
  .action(async () => {
    const { ConfigManager } = await import('../dist/core/config.js');
    const { getMacAddress } = await import('../dist/modules/mac-address.js');
    const { generateSecret } = await import('../dist/modules/auth.js');

    console.log('\n📡 ClawMessenger 设备注册');
    console.log('─'.repeat(50));

    const mac = getMacAddress();
    const secretKey = 'claw_secret_' + mac.slice(0, 8);
    const secret = generateSecret(mac, secretKey);
    const accountId = 'claw_' + mac;

    console.log('  设备 MAC:   ' + mac);
    console.log('  设备账号:   ' + accountId);
    console.log('');

    const config = {
      appKey: 'YOUR_APP_KEY',
      appSecret: 'YOUR_APP_SECRET',
      token: 'YOUR_TOKEN',
      accountId,
      secretKey,
      opencodeUrl: 'http://localhost:19876',
      autoApprove: true,
      p2pPolicy: 'open',
      groupPolicy: 'mention',
    };
    new ConfigManager().save(config);

    // 按 bind_openclaw 协议生成注册二维码
    const qrData = JSON.stringify({
      type: 'bind_openclaw',
      node_id: accountId,
      name: '魂器',
      timestamp: Date.now(),
      mac: mac,
    });
    console.log('📱 请用 ClawMessenger App 扫描注册:\n');
    console.log('  App 扫码后将自动推送融云凭证，无需手动配置。\n');
    try {
      const qrcode = await import('qrcode');
      const qr = await qrcode.default.toString(qrData, { type: 'terminal', small: true });
      console.log(qr);
    } catch (_e) {
      console.log('  (qrcode 未安装)');
      console.log('  注册数据: ' + qrData);
    }
    console.log('');
    console.log('  配置: ~/.config/opencode/rongyun.json');
    console.log('');
  });

program
  .command('start')
  .description('启动桥接服务')
  .action(async () => {
    console.log('🚀 启动 ClawMessenger 桥接...\n');
    const { ConfigManager } = await import('../dist/core/config.js');
    const mgr = new ConfigManager();
    if (!mgr.exists()) {
      console.log('⚠️  未配置: opencode-clawmessenger setup');
      return;
    }
    const config = mgr.load();
    if (config.appKey === 'YOUR_APP_KEY' || config.token === 'YOUR_TOKEN') {
      console.log('⚠️  融云参数未配置，请编辑 ~/.config/opencode/rongyun.json');
      return;
    }

    const { RongyunClient } = await import('../dist/rongyun/client.js');
    const { RongyunMessageHandler } = await import('../dist/core/message-handler.js');
    const { getMacAddress } = await import('../dist/modules/mac-address.js');

    console.log('  设备 MAC:    ' + getMacAddress());
    console.log('  App Key:     ' + config.appKey.slice(0, 6) + '...');
    console.log('  账号:        ' + config.accountId);
    console.log('  OpenCode:    ' + config.opencodeUrl);

    const client = new RongyunClient({
      appKey: config.appKey,
      token: config.token,
      accountId: config.accountId,
      botUserId: config.accountId,
    }, console);

    const handler = new RongyunMessageHandler(config, client, console);

    const ok = await client.connect(handler);
    if (ok) {
      console.log('\n✅ ClawMessenger 桥接已启动');
      client.setHeartbeatHandler(function () { console.log('[Heartbeat]'); });
      client.startHeartbeat(30000);
    } else {
      console.log('\n❌ 连接失败');
      process.exit(1);
    }
  });

program
  .command('doctor')
  .description('检查连接状态')
  .action(async () => {
    const { ConfigManager } = await import('../dist/core/config.js');
    const { getMacAddress } = await import('../dist/modules/mac-address.js');
    const mgr = new ConfigManager();

    console.log('\n🔍 ClawMessenger 诊断');
    console.log('─'.repeat(40));
    console.log('  设备 MAC:    ' + getMacAddress());

    if (mgr.exists()) {
      const cfg = mgr.load();
      console.log('  App Key:     ' + cfg.appKey.slice(0, 6) + '...');
      console.log('  Token:       ' + (cfg.token && cfg.token !== 'YOUR_TOKEN' ? '已配置 ✅' : '未配置 ⚠️'));
      console.log('  账号:        ' + cfg.accountId);
      console.log('  OpenCode:    ' + cfg.opencodeUrl);
    } else {
      console.log('  配置:        未配置 ⚠️');
    }

    try {
      const res = await fetch('http://localhost:19876/health', { signal: AbortSignal.timeout(2000) });
      console.log('  OpenCode:     ' + (res.ok ? '运行中 ✅' : '异常 ❌'));
    } catch (_e) {
      console.log('  OpenCode:     未运行 ⚠️');
    }
    console.log();
  });

program.parse();
